# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# =============================================================================
# Common Settings (all languages)
# =============================================================================

# UTF-8 encoding
[*.{cs,csx,fs,fsx}]
charset = utf-8-bom

# Indentation settings - use spaces (no tabs)
indent_style = space

# Line endings - CRLF for Windows compatibility
[*.{cs,csx,fs,fsx}]
end_of_line = crlf

# Insert final newline
insert_final_newline = true

# Trim trailing whitespace
trim_trailing_whitespace = true

# =============================================================================
# C# Formatting Rules
# =============================================================================

[*.cs]
# Indentation size
indent_size = 4

# Newline before open brace
csharp_newline_before_open_brace = all

# Space before colon in base clause
csharp_space_before_colon_in_inheritance_clause = false

# Space after cast
csharp_space_after_cast = false

# Space within method call parentheses
csharp_space_between_method_call_parameter_parentheses = false

# Space within method declaration parentheses
csharp_space_between_method_declaration_parameter_parentheses = false

# =============================================================================
# C# Specific Rules (based on project conventions)
# =============================================================================

[*.cs]
# Prefer var keyword (implicit typing)
csharp_style_var_elsewhere = true
csharp_style_var_for_built_in_types = true
csharp_style_var_when_type_is_apparent = true

# Expression-bodied members
csharp_style_expression_bodied_accessors = when_on_single_line
csharp_style_expression_bodied_constructors = false
csharp_style_expression_bodied_indexers = when_on_single_line
csharp_style_expression_bodied_lambdas = when_on_single_line
csharp_style_expression_bodied_methods = false
csharp_style_expression_bodied_operators = when_on_single_line
csharp_style_expression_bodied_properties = when_on_single_line

# Pattern matching
csharp_style_pattern_matching_over_as_with_null_check = true
csharp_style_pattern_matching_over_is_with_cast_check = true

# Null-checking
csharp_style_null_check_over_pattern_matching = true

# Simple assignment
csharp_prefer_simple_using_statement = true

# In/Out variables
csharp_style_inlined_variable_declaration = true

# =============================================================================
# XML Documentation Rules
# =============================================================================

[*.cs]
# Keep XML documentation comments aligned
# (project uses XML doc with <summary>, <param>, <returns>, <exception>)

# =============================================================================
# F# Formatting Rules
# =============================================================================

[*.fs]
# Indentation size for F#
indent_size = 4

# =============================================================================
# F# Specific Rules
# =============================================================================

[*.fs]
# F# uses off-side rules (indentation-based), but keep alignment consistent

# =============================================================================
# JSON/Config Files
# =============================================================================

[*.{json,jsonc}]
indent_size = 2
charset = utf-8

# =============================================================================
# XML Files
# =============================================================================

[*.{xml,csproj,props,targets,resx,nuspec}]
indent_size = 2
charset = utf-8

# =============================================================================
# Markdown Files
# =============================================================================

[*.md]
trim_trailing_whitespace = false
insert_final_newline = true

# =============================================================================
# PowerShell Scripts
# =============================================================================

[*.{ps1,psm1,psd1}]
indent_size = 4
charset = utf-8-bom

# =============================================================================
# Batch Files
# =============================================================================

[*.{bat,cmd}]
end_of_line = crlf
insert_final_newline = true
